# overlap gene list
common <- intersect(
  combat$symbol[combat$padj < 0.05],
  pseudo$symbol[pseudo$padj < 0.05]
)

# extract overlap genes'log2FC
df_overlap <- data.frame(
  gene = common,
  fc_combat = combat$log2FoldChange[match(common, combat$symbol)],
  fc_pseudo = pseudo$log2FoldChange[match(common, pseudo$symbol)]
)

# check direction
df_overlap$direction <- ifelse(df_overlap$fc_combat > 0 & df_overlap$fc_pseudo > 0, "Up",
                               ifelse(df_overlap$fc_combat < 0 & df_overlap$fc_pseudo < 0, "Down",
                                      "Opposite"))

# quanticiation
table(df_overlap$direction)

plot(df_overlap$fc_combat, df_overlap$fc_pseudo,
     xlab = "bulk log2FC", ylab = "screen log2FC",
     pch = 19, cex = 0.6,
     col = ifelse(sign(df_overlap$fc_combat) == sign(df_overlap$fc_pseudo),
                  "#A6CEE3","#B2DF8A"))
abline(h = 0, v = 0, col = "gray")

# 
abline(0, 1, col = "black", lty = 2)

# 
fit <- lm(fc_pseudo ~ fc_combat, data = df_overlap)
abline(fit, col = "darkgreen", lwd = 2)

# Pearson correlation
cor_res <- cor.test(df_overlap$fc_combat, df_overlap$fc_pseudo, method = "pearson")
r <- cor_res$estimate
p <- cor_res$p.value

text(x = min(df_overlap$fc_combat), 
     y = max(df_overlap$fc_pseudo), 
     labels = paste0("Pearson r = ", round(r, 3), 
                     ", p = ", signif(p, 3)), 
     pos = 4, col = "darkgreen")

# add legend
legend("topleft",
       legend = c("y = x (ideal)", "Fitted line (trend)",
                  "Same direction", "Opposite direction"),
       col = c("black", "darkgreen", "#A6CEE3","#B2DF8A"),
       lty = c(2, 1, NA, NA),
       pch = c(NA, NA, 19, 19),
       lwd = c(1, 2, NA, NA),
       bty = "n")
